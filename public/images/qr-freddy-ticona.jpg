<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300">
  <!-- Background -->
  <rect fill="#ffffff" width="300" height="300" rx="20"/>

  <!-- QR Code Pattern (Simplified) -->
  <g fill="#000000">
    <!-- Corner squares -->
    <rect x="25" y="25" width="60" height="60"/>
    <rect x="35" y="35" width="40" height="40" fill="#ffffff"/>
    <rect x="45" y="45" width="20" height="20"/>

    <rect x="215" y="25" width="60" height="60"/>
    <rect x="225" y="35" width="40" height="40" fill="#ffffff"/>
    <rect x="235" y="45" width="20" height="20"/>

    <rect x="25" y="215" width="60" height="60"/>
    <rect x="35" y="225" width="40" height="40" fill="#ffffff"/>
    <rect x="45" y="235" width="20" height="20"/>

    <!-- Random pattern for QR effect -->
    <rect x="95" y="25" width="10" height="10"/>
    <rect x="115" y="25" width="10" height="10"/>
    <rect x="135" y="25" width="10" height="10"/>
    <rect x="155" y="25" width="10" height="10"/>
    <rect x="175" y="25" width="10" height="10"/>

    <rect x="25" y="95" width="10" height="10"/>
    <rect x="45" y="95" width="10" height="10"/>
    <rect x="65" y="95" width="10" height="10"/>
    <rect x="25" y="115" width="10" height="10"/>
    <rect x="65" y="115" width="10" height="10"/>

    <rect x="95" y="95" width="80" height="80" fill="#D4AF37"/>
    <rect x="105" y="105" width="60" height="60" fill="#ffffff"/>

    <!-- Center text -->
    <text x="150" y="130" text-anchor="middle" fill="#D4AF37" font-size="11" font-weight="bold" font-family="Arial">FREDDY</text>
    <text x="150" y="145" text-anchor="middle" fill="#000000" font-size="11" font-weight="bold" font-family="Arial">TICONA</text>
    <text x="150" y="165" text-anchor="middle" fill="#D4AF37" font-size="9" font-family="Arial">+591 62408420</text>
  </g>

  <!-- Bottom label -->
  <text x="150" y="275" text-anchor="middle" fill="#666666" font-size="10" font-family="Arial">Banco Mercantil</text>
</svg>