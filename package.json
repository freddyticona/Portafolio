{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run generate-icons && npm run generate-rss && vite build && npm run generate-pages",
    "generate-pages": "node scripts/generate-pages.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-rss": "node scripts/generate-rss.js",
    "prebuild": "npm run generate-icons",
    "optimize-images": "node scripts/optimize-images.js",
    "optimize-images:watch": "nodemon --watch public/images --exec 'npm run optimize-images'",
    "check-images": "node scripts/check-images.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@sentry/node": "^10.67.0",
    "@sentry/react": "^10.67.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/blob": "^2.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.16.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.546.0",
    "marked": "^18.0.7",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.8.26",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
